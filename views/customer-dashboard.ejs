<%- include("partials/header") %>

<div class="row g-4">
  <div class="col-lg-3"><%- include("partials/customer-sidebar") %></div>
  <div class="col-lg-9">
    <h2 class="mb-3">Welcome, <%= customer.full_name %></h2>
    <div class="row g-3">
      <div class="col-md-4"><div class="stat-card"><span>Vehicles</span><strong><%= stats.vehicles %></strong></div></div>
      <div class="col-md-4"><div class="stat-card"><span>Bookings</span><strong><%= stats.bookings %></strong></div></div>
      <div class="col-md-4"><div class="stat-card"><span>Receipts</span><strong><%= stats.receipts %></strong></div></div>
    </div>
    <div class="content-panel mt-4">
      <h5>Quick Actions</h5>
      <a href="/vehicle/add" class="btn btn-outline-primary me-2 mb-2">Register Vehicle</a>
      <a href="/parking/locations" class="btn btn-outline-primary me-2 mb-2">View Locations</a>
      <a href="/parking/book" class="btn btn-primary me-2 mb-2">Book Slot</a>
      <a href="/booking/history" class="btn btn-warning mb-2">Booking / Bill Status</a>
    </div>
  </div>
</div>

<%- include("partials/footer") %>
